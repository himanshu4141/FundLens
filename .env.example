# Supabase — get these from your project's API settings
# New key format (as of late 2025): publishable keys replace the old anon key.
# See: https://github.com/orgs/supabase/discussions/29260
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Google OAuth — enable the Google provider in Supabase Auth > Providers > Google,
# then paste the Web Client ID and Client Secret from Google Cloud Console there.
# This variable is documentation only; the client app does not read it directly
# (Supabase manages Google OAuth server-side using its own redirect URI).
#
# Required redirect URLs to add in Supabase Auth > URL Configuration > Redirect URLs:
#   https://foliolens.vercel.app/auth/callback          ← production + native bridge
#   https://*.vercel.app/auth/callback                  ← Vercel preview deployments (wildcard)
#   foliolens://auth/callback                            ← production app
#   foliolens-main://auth/callback                       ← stable main preview app
#   foliolens-pr://auth/callback                         ← rolling PR preview app
#
# In Google Cloud Console > OAuth 2.0 Client > Authorized redirect URIs, add:
#   https://<project-ref>.supabase.co/auth/v1/callback
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Local-only developer shortcut.
# Keep disabled in production and shared preview environments.
EXPO_PUBLIC_ENABLE_DEV_AUTH_BYPASS=false
EXPO_PUBLIC_DEV_AUTH_EMAIL=demo@foliolens.local
EXPO_PUBLIC_DEV_AUTH_PASSWORD=change-me-local-only

# Local scripts only. Never expose this key in a shared client environment.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Shared secret used between Supabase parse-cas-pdf and the Vercel Python parser.
# Set the same value in Vercel project env and in Supabase Edge Function secrets.
CAS_PARSER_SHARED_SECRET=replace-with-random-secret

# Stable parser URL used by native/mobile clients when request origin is unavailable.
# Example: https://your-vercel-app.vercel.app/api/parse-cas-pdf
LOCAL_CAS_PARSER_URL=https://your-vercel-app.vercel.app/api/parse-cas-pdf

# Optional: required only if your Vercel preview deployments are protected.
# Supabase will send this token when calling the parser so protected previews remain testable.
VERCEL_PROTECTION_BYPASS_TOKEN=optional-preview-bypass-token

# Optional overrides for the local demo seed script.
DEV_DEMO_PAN=ABCDE1234F
DEV_DEMO_KFINTECH_EMAIL=demo-import@example.com

# EAS — only needed for CI/CD (GitHub Actions)
# Create at: https://expo.dev → Account Settings → Access Tokens
EXPO_TOKEN=your_expo_robot_token
